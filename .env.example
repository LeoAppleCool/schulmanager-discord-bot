SM_DISCORD_BOT_TOKEN=
# URL of the running Schulmanager API, reachable FROM INSIDE the bot container.
#   - API + bot on the same host (default here): http://host.docker.internal:8000
#     (works via the extra_hosts mapping in docker-compose.yml, also on Linux)
#   - Or use the host's LAN IP:                  http://192.168.x.x:8000
#   - Or, if both run in one shared Docker network, the API service name: http://api:8000
# NOTE: http://127.0.0.1:8000 does NOT work from inside Docker (points to the container itself).
SM_DISCORD_API_BASE_URL=http://host.docker.internal:8000
SM_DISCORD_SYNC_INTERVAL_SECONDS=120
SM_DISCORD_DB_PATH=data/discord_bot.sqlite3
SM_DISCORD_GUILD_ID=
SM_DISCORD_TIMEZONE=Europe/Berlin
SM_DISCORD_CATEGORY_PREFIX=schulmanager
SM_DISCORD_DIGEST_TIME=07:00
SM_DISCORD_DIGEST_ENABLED=true
SM_DISCORD_LOGGED_IN_ROLE_ID=

SM_LOG_FORMAT=text
SM_LOG_LEVEL=INFO
